<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

  <div class="dashboard">

    <aside class="sidebar">
      <h2>🛡️ Admin</h2>

      <ul>
        <li><a href="#">Dashboard</a></li>
        <li><a href="#">Users</a></li>
        <li><a href="#">Notes</a></li>
        <li><a href="#">Analytics</a></li>
        <li><a href="#">Settings</a></li>
      </ul>
    </aside>

    <main class="main-content">

      <header>
        <h1>Admin Dashboard</h1>
      </header>

      <div class="cards">

        <div class="card">
          <h3>Total Users</h3>
          <p>150</p>
        </div>

        <div class="card">
          <h3>Total Notes</h3>
          <p>425</p>
        </div>

        <div class="card">
          <h3>Admins</h3>
          <p>3</p>
        </div>

        <div class="card">
          <h3>Active Users</h3>
          <p>98</p>
        </div>

      </div>

      <section class="table-section">

        <h2>Recent Users</h2>

        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <td>John</td>
              <td>john@example.com</td>
              <td>User</td>
            </tr>

            <tr>
              <td>Alex</td>
              <td>alex@example.com</td>
              <td>Admin</td>
            </tr>
          </tbody>
        </table>

      </section>

    </main>

  </div>

</body>
</html>
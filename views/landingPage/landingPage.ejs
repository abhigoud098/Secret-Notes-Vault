<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secret Notes Vault</title>
    <link rel="stylesheet" href="/css/landingpage.css" />
  </head>
  <body>
    <div class="background-glow"></div>

    <nav>
      <div class="logo">🔒 Secret Vault</div>
    </nav>

    <section class="hero">
      <div class="hero-content">
        <span class="tag">Private • Secure • Simple</span>

        <h1>Keep Your Notes Safe Inside Your Personal Vault</h1>

        <p>
          Store private thoughts, ideas, passwords, and important information in
          one secure place accessible only by you.
        </p>

        <div class="buttons">
          <a href="/signin" class="primary-btn">Get Started</a>
          <a href="/login" class="secondary-btn">Login</a>
        </div>
      </div>

      <div class="vault-card">
        <div class="lock-icon">🔐</div>

        <h3>Encrypted Notes</h3>

        <p>
          Your notes remain protected and organized inside your personal vault.
        </p>
      </div>
    </section>
  </body>
</html>
